# Entity: system

main: kit: entity: system: {

  alias: field: {}

  fields: [
    {
      name: "status"
      req: false
      type: "`$STRING`"
    }
  ]

  name: "system"
  op: {
    load: {
      name: "load"
      points: [
        {
          method: "GET"
          orig: "/health"
          parts: [
            "health"
          ]
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



}
